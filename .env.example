# ========== 核心配置 ==========
NODE_ENV=development
PORT=3000

# ========== 域名（控制台和 API 共用主域名） ==========
# DOMAIN=aigc.guangai.ai
# API_BASE_URL=https://${DOMAIN}/v1
# SITE_URL=https://${DOMAIN}
# CDN_BASE_URL=https://cdn.${DOMAIN}

# ========== 数据库 ==========
# connection_limit: 连接池大小（staging 共机建议 10，production 建议 20）
# pool_timeout: 等待连接超时秒数
DATABASE_URL=postgresql://user:password@localhost:5432/aigc_gateway?connection_limit=20&pool_timeout=10
# DATABASE_READ_URL=postgresql://user:password@read-host:5432/aigc_gateway

# ========== Redis ==========
REDIS_URL=redis://localhost:6379/0

# ========== 认证 ==========
JWT_SECRET=<random-64-chars>
JWT_EXPIRES_IN=7d

# ========== 加密主密钥（用于加密 Provider.authConfig） ==========
ENCRYPTION_KEY=<random-32-bytes-hex>

# ========== 图片代理 HMAC 签名 ==========
# 三选一：优先 IMAGE_PROXY_SECRET，其次 AUTH_SECRET / NEXTAUTH_SECRET。
# 缺失时应用启动即抛错（见 src/lib/env.ts#assertImageProxySecret）。
IMAGE_PROXY_SECRET=<random-32-bytes-hex>

# ========== 种子/脚本密码（仅本地与 CI，生产禁止设置 ADMIN_SEED_PASSWORD） ==========
# prisma/seed.ts 用 ADMIN_SEED_PASSWORD 创建初始 admin；upsert 幂等，不重置已存在账号。
ADMIN_SEED_PASSWORD=<local-admin-password>
# scripts/admin-auth.ts、stress-test、template-governance-eval 等用此 env 登录测试 admin。
ADMIN_TEST_PASSWORD=<test-admin-password>
# E2E 脚本注册/登录测试用户的密码（替代历史字面量），缺失时脚本 exit(1)。
E2E_TEST_PASSWORD=<e2e-user-password>

# ========== 代理（访问海外服务商） ==========
# PROXY_URL_PRIMARY=socks5://proxy1-host:1080
# PROXY_URL_SECONDARY=socks5://proxy2-host:1080

# ========== 支付 ==========
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=
# ALIPAY_PUBLIC_KEY=
# ALIPAY_NOTIFY_URL=https://${DOMAIN}/api/webhooks/alipay

# WECHAT_MCH_ID=
# WECHAT_API_KEY_V3=
# WECHAT_CERT_SERIAL=
# WECHAT_PRIVATE_KEY=
# WECHAT_NOTIFY_URL=https://${DOMAIN}/api/webhooks/wechat

# ========== 汇率 ==========
EXCHANGE_RATE_CNY_TO_USD=0.137

# ========== 健康检查 ==========
HEALTH_CHECK_ACTIVE_INTERVAL_MS=600000
HEALTH_CHECK_STANDBY_INTERVAL_MS=1800000
HEALTH_CHECK_COLD_INTERVAL_MS=7200000
HEALTH_CHECK_FAIL_THRESHOLD=3

# ========== 限流（默认值） ==========
DEFAULT_RPM=60
DEFAULT_TPM=100000
DEFAULT_IMAGE_RPM=10

# ========== 告警 ==========
# ALERT_WEBHOOK_URL=
# ALERT_EMAIL=

# ========== 日志 ==========
LOG_LEVEL=info
LOG_FORMAT=json
